# Copie este arquivo para .env e preencha com seus valores reais
# cp .env.example .env

# Chave secreta para assinar os tokens JWT (use uma string longa e aleatória)
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria-aqui

# Senha do usuário admin (criado automaticamente na 1ª inicialização)
ADMIN_PASSWORD=troque-por-uma-senha-forte

# URL do banco de dados (padrão: SQLite local)
DATABASE_URL=sqlite:///./jovempano.db

# Orígens adicionais de CORS (opcional — separadas por vírgula)
# EXTRA_CORS_ORIGINS=https://custom-preview-domain.vercel.app

# URL da própria API (usada pelo scripts de keep-alive e seeding remoto)
# BACKEND_URL=http://localhost:8000
