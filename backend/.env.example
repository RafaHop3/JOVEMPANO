# Copie para .env e preencha em produção (nunca commite .env com segredos reais).
SECRET_KEY=troque-por-uma-chave-longa-aleatoria
DATABASE_URL=sqlite:///./jovempano.db

# Usuário inicial do painel /admin (criado no primeiro deploy se ainda não existir)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha

# Apenas se precisar forçar reset de senha do admin no próximo restart (depois volte a false)
FORCE_RESET_ADMIN_PASSWORD=false

# CORS: origem do frontend (Vercel). Pode listar várias em EXTRA_CORS_ORIGINS
FRONTEND_URL=https://jovempanonews.vercel.app
# EXTRA_CORS_ORIGINS=https://outro-dominio.vercel.app
