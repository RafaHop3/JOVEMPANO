---
import Layout from '../layouts/Layout.astro';

// Fetch articles from the FastAPI backend at build time
let articles = [];
try {
	// Assumes the API is running locally during build time
	const response = await fetch('http://localhost:8000/articles/');
	if (response.ok) {
		articles = await response.json();
	}
} catch (error) {
	console.error("Failed to fetch articles. Make sure the FastAPI server is running.", error);
}

// In Astro, to SSG everything perfectly, data is fetched once at build.
---

<Layout title="JovemPano - Capa" description="As notícias mais recentes estruturadas com IA.">
	<main>
		<section class="feed">
			<h2>Últimas Notícias</h2>
			{articles.length === 0 ? (
				<p style="color: var(--text-muted); margin-top: 1rem;">Nenhuma notícia gerada ainda. Execute o crawler e a geração no backend.</p>
			) : (
				<div class="articles-grid">
					{articles.map((article: any) => (
						<article class="card">
							<h3><a href={`/article/${article.id}`}>{article.title}</a></h3>
							<p class="meta">Publicado em: {new Date(article.generated_at).toLocaleDateString('pt-BR')} • Status: <span class="badge">{article.status}</span></p>
						</article>
					))}
				</div>
			)}
		</section>
	</main>
</Layout>

<style>
	h2 {
		color: #fff;
		margin-bottom: 1.5rem;
		font-size: 1.5rem;
	}
	.articles-grid {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	h3 {
		font-size: 1.25rem;
		margin-bottom: 0.5rem;
	}
	.meta {
		font-size: 0.85rem;
		color: var(--text-muted);
	}
	.badge {
		background: #238636;
		color: #fff;
		padding: 2px 6px;
		border-radius: 12px;
		font-size: 0.75rem;
		font-weight: bold;
		text-transform: uppercase;
	}
</style>
